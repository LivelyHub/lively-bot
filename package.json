    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "openai": "^4.56.0",
    "pino": "^9.3.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.15",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
  }
}
