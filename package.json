{
  "name": "lively-bot",
  "version": "0.1.0",
  "private": true,
  "description": "AI companion service for Lively — Mbak Asih and Mas Budi. Receives processed chat from lively-backend, returns AI replies.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
