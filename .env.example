# HTTP server
PORT=7002                     # port the /reply service listens on

# LLM provider (OpenAI primary, OpenRouter free model as fallback)
OPENAI_BASE_URL=              # custom OpenAI-compatible provider endpoint, e.g. https://your-provider.com/v1
OPENAI_API_KEY=              # your OpenAI key — DO NOT COMMIT the real one
OPENAI_MODEL=                # e.g. gpt-4o-mini
OPENROUTER_BASE_URL= 
OPENROUTER_API_KEY=           # openrouter.ai key — DO NOT COMMIT the real one; free models still require a key
OPENROUTER_MODEL=             # e.g. meta-llama/llama-3.1-8b-instruct:free — used when OpenAI is unset or a call fails

# Backend (per CORE.md)
BACKEND_API_URL=              # e.g. https://api.lively.example.com
BOT_SERVICE_KEY=              # shared secret for service-to-service auth with lively-backend

# SQLite database for conversation memory + long-term remembrances (gitignored)
DATABASE_PATH=./data/lively.db