# WhatsApp Cloud API (per CORE.md §4)
WHATSAPP_CLOUD_API_TOKEN=   # Meta Cloud API access token — DO NOT COMMIT the real one
WHATSAPP_PHONE_NUMBER_ID=   # Meta-assigned phone number ID for the companion's WA number
WHATSAPP_VERIFY_TOKEN=      # webhook verification token you choose, must match Meta app config

# LLM provider
OPENAI_API_KEY=             # your OpenAI key — DO NOT COMMIT the real one
OPENAI_MODEL=                # e.g. gpt-4o

# Backend (per CORE.md)
BACKEND_API_URL=            # e.g. https://api.lively.example.com
BOT_SERVICE_KEY=            # shared secret for service-to-service auth with lively-backend
